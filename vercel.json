{
  "version": 2,
  "builds": [
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/favicon.svg", "dest": "/favicon.svg" },
    { "src": "/favicon-32x32.png", "dest": "/favicon-32x32.png" },
    { "src": "/apple-touch-icon.png", "dest": "/apple-touch-icon.png" },
    { "src": "/resume.pdf", "dest": "/resume.pdf" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
